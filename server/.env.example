# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
DB_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/ecommerce_app?retryWrites=true&w=majority

# Session Secret - Use a strong, random string in production
SESSION_SECRET=your_secret_key_here

# Frontend URL - Update when deploying to production
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
